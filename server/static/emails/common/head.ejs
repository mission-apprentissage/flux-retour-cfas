<mj-head>
    <mj-title>Tableau de bord de l'apprentissage</mj-title>
    <mj-style inline="inline">
        .link-nostyle { color: inherit; }
        .highlight { font-weight:600; }
        .left { padding-right: 5px; }
        .right { padding-left: 5px; }
        .icon { vertical-align: middle }
    </mj-style>
    <mj-style>
        @media only screen and (max-width: 480px) {
            .mobile-wrapper-tight > table > tbody > tr > td {
                padding-left: 0 !important;
                padding-right: 0 !important;
            }
            .mobile-section-narrow > table > tbody > tr > td {
                padding-left: 0 !important;
                padding-right: 0 !important;
            }
            .mobile-padding-sm,
            .mobile-padding-sm > table > tbody > tr > td {
                padding: 12px !important;
            }
            .mobile-column-padding-sm > table > tbody > tr > td {
                padding: 10px !important;
            }
            .mobile-text-tight {
                padding-left: 10px !important;
                padding-right: 10px !important;
            }
            .mobile-text-14 {
                padding-left: 15px !important;
                padding-right: 15px !important;
            }
            .mobile-text-14 div, .mobile-text-14 p {
                font-size: 14px !important;
                line-height: 20px !important;
            }
            .mobile-text-16 div, .mobile-text-16 p {
                font-size: 16px !important;
                line-height: 22px !important;
            }
            .mobile-full-btn {
                padding-left: 10px !important;
                padding-right: 10px !important;
            }
            .mobile-full-btn table {
                width: 100% !important;
            }
            .mobile-full-btn a {
                display: block !important;
                box-sizing: border-box !important;
            }
        }
    </mj-style>
    <mj-attributes>
        <mj-table
                color="#3C4858"
                font-family="Arial,Helvetica,sans-serif,sans-serif"
                font-size="14px"
        />
        <mj-text
                color="#3C4858"
                font-family="Arial,Helvetica,sans-serif,sans-serif"
                font-size="14px"
                font-weight="400"
                font-style="normal"
                line-height="21px"
                align="left"
        />
        <mj-button
                background-color="#EC615B"
                align="center"
                font-size="14px"
                line-height="23px"
                border-radius="13px"
                font-weight="600"
        />
    </mj-attributes>
</mj-head>
