<mjml>
  <%- include('./common/head.ejs'); %>

    <mj-body background-color="#f9fafc">
      <%- include('./common/header.ejs'); %>
        <mj-wrapper padding="10px 20px">
          <mj-section background-color="#ffffff" padding-top="0">
            <mj-column>
              <mj-text> Bonjour, </mj-text>
              <mj-text>
                <div>
                  <br />
                  L'utilisateur <strong><%= data.user.email %></strong> demande un accès :
                </div>
                <ul>
                  <li>
                    <%= data.user.nom %>
                    <%= data.user.prenom %>
                  </li>
                  <li>Organisation : <%= data.organisationLabel %>
                  </li>
                </ul>
              </mj-text>
              <mj-button
                href="<%= utils.getPublicUrl(`/api/v1/admin/users/confirm-user?userEmail=${encodeURIComponent(data.user.email)}&organisme_id=all&validate=true`) %>"
                background-color="#0e4194" color="white">
                Ok je confirme cet utilisateur
              </mj-button>
              <mj-button
                href="<%= utils.getPublicUrl(`/api/v1/admin/users/confirm-user?userEmail=${encodeURIComponent(data.user.email)}&organisme_id=all&validate=false`) %>"
                background-color="#ff0000" color="white">
                Cet utilisateur n'a pas le droit d'accéder à cet organisme
              </mj-button>
            </mj-column>
          </mj-section>
        </mj-wrapper>
    </mj-body>
</mjml>
